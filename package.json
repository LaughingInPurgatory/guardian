{
  "name": "guardian",
  "productName": "Guardian",
  "version": "1.1.2",
  "description": "A modern, endless remake of the classic arcade game Defender",
  "main": "main.js",
  "author": "LaughingInPurgatory",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "test": "node --test",
    "dist": "electron-builder -mwl"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.gkorbey.guardian",
    "productName": "Guardian",
    "directories": {
      "output": "release"
    },
    "icon": "build/icon.png",
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "styles.css",
      "src/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.action-games",
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "afterSign": "scripts/afterSign.js",
    "linux": {
      "category": "Game",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "publish": [
      {
        "provider": "github"
      }
    ]
  },
  "allowScripts": {
    "electron@33.4.11": true
  }
}
